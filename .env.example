# Firebase (Project settings → Your apps → Web app config)
# In Authentication → Sign-in method: enable Email/Password (primary). Enable Google only if you still use “Sign in with Google”.
# New users: add them in Team (Sanity crmUser) and create the same email in Firebase Auth (Console or Admin SDK)—the app does not offer self-registration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Google AI Studio API key for AI reply drafts (never commit real keys)
# https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Optional: first name used in WhatsApp AI opener (“this is X from Asahi Motors”),
# if you don’t want to rely on Google display name
VITE_STAFF_FIRST_NAME=

# @asahigroup.co.uk addresses are always superadmin (Team + full nav); see SUPERADMIN_EMAIL_DOMAINS in src/constants.js.
# Optional: extra superadmin emails (any domain), comma-separated:
# VITE_SUPERADMIN_EMAILS=founder@example.com
VITE_SUPERADMIN_EMAILS=

# Sanity (leads DB). Create an API token (Editor) at sanity.io → Project → API.
# Add this origin under API → CORS: http://localhost:5173 and your production URL.
# Never commit a real token. Deploy the schema once: cd studio && npm i && npx sanity schema deploy
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_TOKEN=
